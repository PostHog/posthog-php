{
	"name": "posthog/posthog-php",
	"version": "4.5.0",
	"description": "PostHog PHP Library",
	"keywords": [
		"posthog"
	],
	"homepage": "https://github.com/PostHog/posthog-php",
	"license": "MIT",
	"authors": [
		{
			"name": "PostHog <engineering@posthog.com>",
			"homepage": "https://posthog.com/"
		}
	],
	"require": {
		"ext-json": "*",
		"php": ">=8.2",
		"psr/simple-cache": "^1.0|^2.0|^3.0",
		"symfony/clock": "^6.2|^7.0|^8.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"squizlabs/php_codesniffer": "^3.7",
		"symfony/cache": "^6.0|^7.0|^8.0"
	},
	"suggest": {
		"psr/simple-cache-implementation": "A PSR-16 cache (e.g. symfony/cache) to share local feature flag definitions across requests"
	},
	"autoload": {
		"psr-4": {
			"PostHog\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"PostHog\\Test\\": "test/",
			"PostHog\\Test\\Assets\\": "test/assests"
		}
	},
	"bin": [
		"bin/posthog"
	]
}
